# AI extraction.
# local = rule-based, openai = OpenAI-compatible API only, hybrid = AI with local fallback.
RESEARCH_LOOP_EXTRACTOR=local
OPENROUTER_API_KEY=
OPENAI_MODEL=deepseek/deepseek-v4-flash
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# OpenRouter example:
# RESEARCH_LOOP_EXTRACTOR=hybrid
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=deepseek/deepseek-v4-flash
# RESEARCH_LOOP_MAX_OUTPUT_TOKENS=1200
#
# Free option, if available and reliable enough:
# OPENAI_MODEL=deepseek/deepseek-v4-flash:free

# Optional runtime settings for scripts or future deployment wrappers.
RESEARCH_LOOP_DB_PATH=data/research_loop.sqlite3
RESEARCH_LOOP_DIGEST_DIR=digests
RESEARCH_LOOP_LOG_PATH=logs/research_loop.jsonl
