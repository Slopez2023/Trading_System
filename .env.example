# AI extraction.
# local = rule-based, openai = OpenAI only, hybrid = OpenAI with local fallback.
RESEARCH_LOOP_EXTRACTOR=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter example:
# RESEARCH_LOOP_EXTRACTOR=hybrid
# OPENAI_API_KEY=sk-or-v1-your-key-here
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=qwen/qwen3-30b-a3b-instruct-2507
# RESEARCH_LOOP_MAX_OUTPUT_TOKENS=1200

# Optional runtime settings for scripts or future deployment wrappers.
RESEARCH_LOOP_DB_PATH=data/research_loop.sqlite3
RESEARCH_LOOP_DIGEST_DIR=digests
